;;
;; Routing of a Contract Subscription
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'subscriptions) = $Subscription$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
    }
    ;; Receive Withdraw message
    if (op == 195467089) {
        var $msg'amount = in_msg~load_varuint16();
        throw_unless(49469, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(54615, ($global_myBalance() >= ($msg'amount + 50000000)));
        $global_send($SendParameters$_constructor_to_value_mode_bounce_body($self'owner, $msg'amount, 2, false, __gen_cell_cell_3d46e16f7bc13e8cca0c8dc20ca3555e8380a047dfed6f12d191bd5220d3a4c3()));
        $Subscription$_contract_store(($self'owner, $self'subscriptions));
        return ();
    }
    
    ;; Receive Deploy message
    if (op == 0x946a98b6) {
        var $deploy'queryId = in_msg~load_uint(64);
        ($self'owner, $self'subscriptions)~$Subscription$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
        $Subscription$_contract_store(($self'owner, $self'subscriptions));
        return ();
    }
    
    ;; Receive empty message
    if ((op == 0) & (in_msg_length <= 32)) {
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        slice $sender = $ctx'sender;
        int $tier = 0;
        if (($ctx'value >= 20000000000)) {
            $tier = 3;
        } elseif (($ctx'value >= 5000000000)) {
            $tier = 2;
        } elseif (($ctx'value >= 1000000000)) {
            $tier = 1;
        } else {
            throw(101);
        }
        int $current_time = $global_now();
        int $base_time = $current_time;
        tuple $existing = $SubscriptionData$_load_opt(__tact_dict_get_slice_cell($self'subscriptions, 267, $sender));
        if ((~ null?($existing))) {
            var ($existingData'tier, $existingData'expiresAt) = $SubscriptionData$_not_null($existing);
            if (($existingData'expiresAt > $current_time)) {
                $base_time = $existingData'expiresAt;
            }
        }
        int $new_expiry = ($base_time + 2592000);
        $self'subscriptions~__tact_dict_set_slice_cell(267, $sender, $SubscriptionData$_store_cell($SubscriptionData$_constructor_tier_expiresAt($tier, $new_expiry), begin_cell()));
        $Subscription$_contract_store(($self'owner, $self'subscriptions));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}
